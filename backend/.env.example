# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
PHONE_HMAC_SECRET=your-phone-hmac-secret-min-32-chars
PHONE_ENC_KEY=your-64-char-hex-key-for-aes256gcm

# Meta / WhatsApp
META_WA_TOKEN=your-meta-access-token
META_WA_PHONE_ID=your-whatsapp-phone-number-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-webhook-verify-token

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Dev only — bypasses JWT auth; NEVER set in production
# DEV_BUSINESS_ID=your-business-uuid-from-supabase
